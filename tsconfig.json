{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2025",

    "types": ["node"],
    "lib": ["ESNext", "Decorators"],

    "strict": true,
    "skipLibCheck": true,


    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": true
  }
}
